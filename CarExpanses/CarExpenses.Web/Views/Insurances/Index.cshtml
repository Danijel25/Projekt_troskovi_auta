@model IReadOnlyList<Insurance>
@{
    ViewData["Title"] = "Insurances";
}

<main class="auto-page-container">
    <header class="auto-page-header">
        <p class="auto-kicker">Policy records</p>
        <h1 class="auto-title">Insurances</h1>
    </header>

    <section class="auto-grid" aria-label="Insurance list">
        @foreach (var item in Model)
        {
            <article class="auto-card">
                <div class="auto-card-badge">Car @item.CarId</div>
                <div class="auto-card-content">
                    <h2 class="auto-card-title">@item.Company <span>@item.InsuranceType</span></h2>
                    <dl class="auto-stats">
                        <dt>Price</dt>
                        <dd>@item.Price.ToString("C")</dd>
                        <dt>Ends</dt>
                        <dd>@item.EndDate.ToString("yyyy-MM-dd")</dd>
                    </dl>
                </div>
                <footer class="auto-card-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="auto-btn auto-btn-primary" aria-label="View insurance @item.Id">Details</a>
                </footer>
            </article>
        }
    </section>
</main>
