@model Insurance
@{
    ViewData["Title"] = "Insurance Details";
}

<main class="auto-page-container">
    <nav class="auto-breadcrumb"><a asp-action="Index" class="auto-btn auto-btn-ghost">Back to Insurances</a></nav>
    <article class="auto-details-hero">
        <header class="auto-details-header">
            <div>
                <p class="auto-kicker">Policy details</p>
                <h1 class="auto-hero-title">@Model.Company</h1>
            </div>
            <span class="auto-hero-tag">ID @Model.Id</span>
        </header>
        <div class="auto-details-body">
            <section class="auto-data-panel">
                <h2 class="auto-panel-heading">Insurance Details</h2>
                <ul class="auto-data-list">
                    <li><strong>Id:</strong> @Model.Id</li>
                    <li><strong>Car Id:</strong> @Model.CarId</li>
                    <li><strong>Company:</strong> @Model.Company</li>
                    <li><strong>Insurance Type:</strong> @Model.InsuranceType</li>
                    <li><strong>Price:</strong> @Model.Price.ToString("C")</li>
                    <li><strong>Start Date:</strong> @Model.StartDate.ToString("yyyy-MM-dd")</li>
                    <li><strong>End Date:</strong> @Model.EndDate.ToString("yyyy-MM-dd")</li>
                </ul>
            </section>
            <aside class="auto-action-panel">
                <h3 class="auto-panel-heading">Actions</h3>
                <a asp-action="Index" class="auto-btn auto-btn-secondary">View All Insurances</a>
            </aside>
        </div>
    </article>
</main>
