@model IReadOnlyList<ServiceRecord>
@{
    ViewData["Title"] = "Service Records";
}

<main class="auto-page-container">
    <header class="auto-page-header">
        <p class="auto-kicker">Maintenance log</p>
        <h1 class="auto-title">Service Records</h1>
    </header>

    <section class="auto-grid" aria-label="Service records list">
        @foreach (var item in Model)
        {
            <article class="auto-card">
                <div class="auto-card-badge">Car @item.CarId</div>
                <div class="auto-card-content">
                    <h2 class="auto-card-title">@item.ServiceType <span>#@item.Id</span></h2>
                    <dl class="auto-stats">
                        <dt>Cost</dt>
                        <dd>@item.Cost.ToString("C")</dd>
                        <dt>Date</dt>
                        <dd>@item.ServiceDate.ToString("yyyy-MM-dd")</dd>
                    </dl>
                </div>
                <footer class="auto-card-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="auto-btn auto-btn-primary" aria-label="View service record @item.Id">Details</a>
                </footer>
            </article>
        }
    </section>
</main>
