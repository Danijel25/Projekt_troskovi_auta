@model ExpenseCategory
@{
    ViewData["Title"] = "Expense Category Details";
}

<main class="auto-page-container">
    <nav class="auto-breadcrumb"><a asp-action="Index" class="auto-btn auto-btn-ghost">Back to Expense Categories</a></nav>
    <article class="auto-details-hero">
        <header class="auto-details-header">
            <div>
                <p class="auto-kicker">Category details</p>
                <h1 class="auto-hero-title">@Model.Name</h1>
            </div>
            <span class="auto-hero-tag">ID @Model.Id</span>
        </header>
        <div class="auto-details-body">
            <section class="auto-data-panel">
                <h2 class="auto-panel-heading">Category Details</h2>
                <ul class="auto-data-list">
                    <li><strong>Id:</strong> @Model.Id</li>
                    <li><strong>Name:</strong> @Model.Name</li>
                    <li><strong>Assigned Expenses:</strong> @(Model.Expenses?.Count ?? 0)</li>
                </ul>
            </section>
            <aside class="auto-action-panel">
                <h3 class="auto-panel-heading">Actions</h3>
                <a asp-action="Index" class="auto-btn auto-btn-secondary">View All Categories</a>
            </aside>
        </div>
    </article>
</main>
