@model IReadOnlyList<FuelExpense>
@{
    ViewData["Title"] = "Fuel Expenses";
}

<main class="auto-page-container">
    <header class="auto-page-header">
        <p class="auto-kicker">Fuel log</p>
        <h1 class="auto-title">Fuel Expenses</h1>
    </header>

    <section class="auto-grid" aria-label="Fuel expenses list">
        @foreach (var item in Model)
        {
            <article class="auto-card">
                <div class="auto-card-badge">Car @item.CarId</div>
                <div class="auto-card-content">
                    <h2 class="auto-card-title">Expense <span>#@item.Id</span></h2>
                    <dl class="auto-stats">
                        <dt>Total</dt>
                        <dd>@item.TotalCost.ToString("C")</dd>
                        <dt>Date</dt>
                        <dd>@item.FuelExpenseDate.ToString("yyyy-MM-dd")</dd>
                    </dl>
                </div>
                <footer class="auto-card-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="auto-btn auto-btn-primary" aria-label="View fuel expense @item.Id">Details</a>
                </footer>
            </article>
        }
    </section>
</main>
