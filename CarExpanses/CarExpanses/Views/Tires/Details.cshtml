@model Tire
@{
    ViewData["Title"] = "Tire Details";
}

<main class="auto-page-container">
    <nav class="auto-breadcrumb"><a asp-action="Index" class="auto-btn auto-btn-ghost">Back to Tires</a></nav>
    <article class="auto-details-hero">
        <header class="auto-details-header">
            <div>
                <p class="auto-kicker">Hardware profile</p>
                <h1 class="auto-hero-title">@Model.Brand @Model.Model</h1>
            </div>
            <span class="auto-hero-tag">ID @Model.Id</span>
        </header>
        <div class="auto-details-body">
            <section class="auto-data-panel">
                <h2 class="auto-panel-heading">Tire Details</h2>
                <ul class="auto-data-list">
                    <li><strong>Id:</strong> @Model.Id</li>
                    <li><strong>Brand:</strong> @Model.Brand</li>
                    <li><strong>Model:</strong> @Model.Model</li>
                    <li><strong>Season:</strong> @Model.Season</li>
                    <li><strong>Price:</strong> @Model.Price.ToString("C")</li>
                    <li><strong>Assignments:</strong> @(Model.CarTires?.Count ?? 0)</li>
                </ul>
            </section>
            <aside class="auto-action-panel">
                <h3 class="auto-panel-heading">Actions</h3>
                <a asp-action="Index" class="auto-btn auto-btn-secondary">View All Tires</a>
            </aside>
        </div>
    </article>
</main>
