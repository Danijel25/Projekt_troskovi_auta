@model CarTire
@{
    ViewData["Title"] = "Car Tire Details";
}

<main class="auto-page-container">
    <nav class="auto-breadcrumb"><a asp-action="Index" class="auto-btn auto-btn-ghost">Back to Car Tires</a></nav>
    <article class="auto-details-hero">
        <header class="auto-details-header">
            <div>
                <p class="auto-kicker">Installation details</p>
                <h1 class="auto-hero-title">Car @Model.CarId / Tire @Model.TireId</h1>
            </div>
            <span class="auto-hero-tag">Pairing</span>
        </header>
        <div class="auto-details-body">
            <section class="auto-data-panel">
                <h2 class="auto-panel-heading">Assignment Details</h2>
                <ul class="auto-data-list">
                    <li><strong>Car Id:</strong> @Model.CarId</li>
                    <li><strong>Tire Id:</strong> @Model.TireId</li>
                    <li><strong>Installed Date:</strong> @Model.InstalledDate.ToString("yyyy-MM-dd")</li>
                </ul>
            </section>
            <aside class="auto-action-panel">
                <h3 class="auto-panel-heading">Actions</h3>
                <a asp-action="Index" class="auto-btn auto-btn-secondary">View All Assignments</a>
            </aside>
        </div>
    </article>
</main>
