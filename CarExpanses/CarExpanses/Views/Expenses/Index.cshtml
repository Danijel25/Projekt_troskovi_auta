@model IReadOnlyList<Expense>
@{
    ViewData["Title"] = "Expenses";
}

<main class="auto-page-container">
    <header class="auto-page-header">
        <p class="auto-kicker">Expense ledger</p>
        <h1 class="auto-title">Expenses</h1>
    </header>

    <section class="auto-grid" aria-label="Expenses list">
        @foreach (var item in Model)
        {
            <article class="auto-card">
                <div class="auto-card-badge">@item.Date.ToString("MM/dd")</div>
                <div class="auto-card-content">
                    <h2 class="auto-card-title">@item.Amount.ToString("C") <span>#@item.Id</span></h2>
                    <dl class="auto-stats">
                        <dt>Category</dt>
                        <dd>@item.Category.Name</dd>
                        <dt>Description</dt>
                        <dd>@item.Description</dd>
                    </dl>
                </div>
                <footer class="auto-card-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="auto-btn auto-btn-primary" aria-label="View expense @item.Id">Details</a>
                </footer>
            </article>
        }
    </section>
</main>
