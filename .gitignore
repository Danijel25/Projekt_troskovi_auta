# .gitignore for ASP.NET MVC project
# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
.vs/

# Rider
.idea/
*.sln.iml

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish results
*.Publish.xml
*.pubxml
*.publishproj

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Windows image file caches
Thumbs.db
Desktop.ini

# Others
*.log
*.vspscc
*.vssscc
*.dbmdl
*.bak
*.backup
*.mdf
*.ldf

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# TeamCity
_TeamCity*

# DotTrace
*.dotTrace

# Rider
.idea/
*.sln.iml

# Local History for Visual Studio
.localhistory/

# SQL Server files
*.mdf
*.ldf

# Azure Web App publish settings
PublishProfiles/

# User secrets
secrets.json

# IIS Express
. vs/
*.vspscc
*.vssscc

# Test results
TestResults/

# Coverage results
*.coverage
*.coveragexml

# node.js
node_modules/

# Yarn
.yarn/
.pnp.*

# JetBrains Rider
.idea/
*.sln.iml

# Backup & report files from converting an old project file
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# End of .gitignore
